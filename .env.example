# Copy this file to .env and fill in real values. docker-compose.yml reads
# a .env file in this directory automatically. Variable names here match
# exactly what backend/src/main/resources/application-prod.properties reads
# -- they are not aspirational names from documentation.

# Database
DATABASE_URL=jdbc:mysql://mysql:3306/techiefinder
DATABASE_USERNAME=root
DATABASE_PASSWORD=change-me

# JWT signing secret. Must be at least 64 bytes (512 bits) since tokens are
# signed with HS512. Never reuse the dev-only default from application.properties
# in a real deployment.
JWT_SECRET=change-me-to-a-random-64-plus-byte-string

# Payment gateway: leave PAYMENT_GATEWAY_PROVIDER unset (or "wallet") to keep
# the instant simulated wallet settlement. Set it to "paystack" or
# "flutterwave" AND the matching secret key below to switch on the real
# integration (PaymentService checks out through the real API and returns a
# checkout URL instead of settling instantly).
PAYMENT_GATEWAY_PROVIDER=wallet
PAYMENT_CALLBACK_URL=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET_HASH=

# Firebase Cloud Messaging (push notifications). Point this at a real service
# account JSON (e.g. file:/path/to/firebase-service-account.json) to enable
# push; without one, push sends are a safe no-op.
FIREBASE_CONFIG_PATH=classpath:firebase-service-account.json

# Email (SMTP). Without real credentials, email sends are a safe no-op.
EMAIL_USERNAME=
EMAIL_PASSWORD=

# SMS (Termii). Without a real key, SMS sends are a safe no-op.
SMS_API_KEY=

# Default admin account, seeded on first startup if it doesn't already exist.
# ADMIN accounts can never self-register (see AuthService.register).
ADMIN_EMAIL=admin@techiefinder.com
ADMIN_PASSWORD=change-me

# Google Maps (not yet used by the backend; geo search today takes raw
# latitude/longitude from the client)
GOOGLE_MAPS_API_KEY=

# Mobile app only -- set this to override the API base URL (e.g. your LAN IP
# for a physical device, or 10.0.2.2 for the Android emulator). Not read by
# the backend or docker-compose.
EXPO_PUBLIC_API_URL=http://localhost:8080/api

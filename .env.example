# Copy this file to .env and fill in real values. docker-compose.yml reads
# a .env file in this directory automatically. Variable names here match
# exactly what backend/src/main/resources/application-prod.properties reads
# -- they are not aspirational names from documentation.

# Database
DATABASE_URL=jdbc:mysql://mysql:3306/techiefinder
DATABASE_USERNAME=root
DATABASE_PASSWORD=change-me

# JWT signing secret. Must be at least 64 bytes (512 bits) since tokens are
# signed with HS512. Never reuse the dev-only default from application.properties
# in a real deployment.
JWT_SECRET=change-me-to-a-random-64-plus-byte-string

# Payment gateways (wallet-only payment flow is implemented today; wire these
# in when adding real Paystack/Flutterwave gateway calls)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# Firebase Cloud Messaging (push notifications -- not yet implemented)
FIREBASE_CONFIG_PATH=classpath:firebase-service-account.json

# Email (not yet implemented)
EMAIL_USERNAME=
EMAIL_PASSWORD=

# SMS (not yet implemented)
SMS_API_KEY=

# Google Maps (not yet used by the backend; geo search today takes raw
# latitude/longitude from the client)
GOOGLE_MAPS_API_KEY=

# Mobile app only -- set this to override the API base URL (e.g. your LAN IP
# for a physical device, or 10.0.2.2 for the Android emulator). Not read by
# the backend or docker-compose.
EXPO_PUBLIC_API_URL=http://localhost:8080/api

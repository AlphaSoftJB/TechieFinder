# Copy to .env.local for local overrides. In dev, Vite's server proxy
# (vite.config.ts) already forwards /api to the backend on :8080, so this
# isn't needed unless you're pointing at a different/deployed backend.
VITE_API_URL=http://localhost:8080/api

# Google/Apple sign-in buttons only render when these are set -- they're
# public client identifiers, not secrets, but the backend must be configured
# with the *same* values (GOOGLE_OAUTH_CLIENT_ID / APPLE_OAUTH_CLIENT_ID) so
# it accepts the resulting ID token's audience.
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
# Apple's JS SDK popup flow needs this to match a Return URL registered on
# the Apple Service ID. Defaults to window.location.origin if unset.
VITE_APPLE_REDIRECT_URI=

{
  "expo": {
    "name": "TechieFinder",
    "slug": "techiefinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B8B4D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.techiefinder.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TechieFinder needs access to your camera to upload portfolio photos.",
        "NSPhotoLibraryUsageDescription": "TechieFinder needs access to your photos to upload portfolio images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B8B4D"
      },
      "package": "com.techiefinder.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}

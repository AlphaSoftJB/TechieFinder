# ===========================
# TechieFinder Monorepo .gitignore
# ===========================

# --- Backend ---
backend/target/
backend/*.jar
backend/*.war
backend/.mvn/wrapper/maven-wrapper.jar
backend/mvnw
backend/mvnw.cmd

# --- Mobile ---
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/*.jks
mobile/*.p8
mobile/*.p12
mobile/*.key
mobile/*.mobileprovision
mobile/google-play-service-account.json

# --- Web Frontend ---
web/node_modules/
web/dist/
web/.vite/

# --- Generator scripts (not needed in production) ---
generate_backend.sh
generate_services.sh
generate_controllers.sh

# --- OS & Editor ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Environment & Secrets ---
*.env
*.env.local
*.env.production
*.env.staging

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
